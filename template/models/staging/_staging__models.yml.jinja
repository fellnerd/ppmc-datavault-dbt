  - name: adworks_verkauf_detail
    description: Staging view for verkauf_detail from adworks
    config:
      meta:
        entity_type: standard
        source_type: external_table
        external_table: ext_adventureworks_saleslt_salesorderdetail
        foreign_keys:
          - column: salesorderid
            target_entity: verkauf
            target_hub: adworks.hub_verkauf
          - column: productid
            target_entity: produkt
            target_hub: adworks.hub_produkt
        dependent_child_keys:
          adworks.hub_verkauf:
            - salesorderdetailid
