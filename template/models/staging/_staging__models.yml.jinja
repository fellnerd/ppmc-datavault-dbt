version: 2
models:
{% if include_example %}
  - name: adworks_adresse
    description: Staging view for adresse from adworks
    config:
      meta:
        entity_type: standard
        source_type: external_table
        external_table: ext_adventureworks_saleslt_address
        business_keys:
          - ADDRESSID
    columns:
      - name: hk_adresse
        description: Hash Key (Primary Key)
        data_type: char(64)
        tests:
          - not_null
          - unique
      - name: hd_adresse
        description: Hash Diff for change detection
        data_type: char(64)
        tests:
          - not_null
      - name: ADDRESSID
        description: Business Key
        tests:
          - not_null
      - name: addressline1
        description: Payload attribute
      - name: addressline2
        description: Payload attribute
      - name: city
        description: Payload attribute
      - name: stateprovince
        description: Payload attribute
      - name: countryregion
        description: Payload attribute
      - name: postalcode
        description: Payload attribute
      - name: modifieddate
        description: Payload attribute
      - name: dss_record_source
        description: Data source identifier
        data_type: varchar(100)
        tests:
          - not_null
      - name: dss_load_date
        description: Load timestamp
        data_type: datetime2(7)
        tests:
          - not_null
      - name: dss_run_id
        description: dbt run identifier
