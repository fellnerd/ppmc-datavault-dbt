-- Creates the empty schemas this project expects in a fresh target database.
-- Run once per new database (dev/test/prod) before the first `dbt run`.
--
--   sqlcmd -S {{ warehouse_server_example }} -d <YOUR_DATABASE> -G -i scripts/setup_schemas.sql

IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name = '{{ staging_schema }}')
    EXEC('CREATE SCHEMA {{ staging_schema }}');

IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name = '{{ schema_prefix }}')
    EXEC('CREATE SCHEMA {{ schema_prefix }}');

IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name = '{{ mart_schema }}')
    EXEC('CREATE SCHEMA {{ mart_schema }}');
{% if include_example %}
IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name = '{{ schema_prefix }}_adworks')
    EXEC('CREATE SCHEMA {{ schema_prefix }}_adworks');
{% endif %}
