{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": { "value": "{{ infra_location }}" },
    "sqlServerName": { "value": "{{ infra_sql_server_name }}" },
    "aadAdminGroupName": { "value": "<your-aad-admin-group-name>" },
    "aadAdminGroupObjectId": { "value": "<your-aad-admin-group-object-id>" },
    "sqlAdminLogin": { "value": "sqladmin" },
    "sqlAdminPassword": { "value": "<use-a-secret-or-secure-parameter-file-not-this-file>" },
    "databaseBaseName": { "value": "{{ database_name }}" },
    "storageAccountName": { "value": "{{ infra_storage_account_name }}" },
    "storageContainerName": { "value": "{{ infra_storage_container_name }}" }
  }
}
